# Segredo usado para assinar/verificar a sessão (JWT). SOMENTE servidor —
# NUNCA prefixar com NEXT_PUBLIC_ e nunca commitar o valor real.
# Gere um valor aleatório longo, por exemplo:
#   openssl rand -base64 48
SESSION_SECRET=troque-por-uma-string-aleatoria-longa

# Opcional: credenciais do usuário ADMIN criado automaticamente na primeira
# execução (apenas se o banco ainda não tiver nenhum usuário). Se omitido,
# o padrão é admin@local.app / admin123 — troque a senha após o primeiro login.
ADMIN_PADRAO_EMAIL=admin@local.app
ADMIN_PADRAO_SENHA=admin123
